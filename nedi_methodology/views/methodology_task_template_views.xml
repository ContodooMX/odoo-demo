<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_template_tree" model="ir.ui.view">
        <field name="name">methodology.task.template.tree</field>
        <field name="model">methodology.task.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="module_id"/>
                <field name="phase"/>
                <field name="task_type"/>
                <field name="estimated_hours"/>
            </list>
        </field>
    </record>

    <record id="view_task_template_form" model="ir.ui.view">
        <field name="name">methodology.task.template.form</field>
        <field name="model">methodology.task.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="module_id"/>
                            <field name="phase"/>
                        </group>
                        <group>
                            <field name="task_type"/>
                            <field name="estimated_hours"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Descripción..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_task_template" model="ir.actions.act_window">
        <field name="name">Templates de Tareas</field>
        <field name="res_model">methodology.task.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_task_templates" name="Templates de Tareas" parent="menu_methodology_config" action="action_task_template" sequence="30"/>
</odoo>
