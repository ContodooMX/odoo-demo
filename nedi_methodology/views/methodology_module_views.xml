<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_module_catalog_tree" model="ir.ui.view">
        <field name="name">methodology.module.catalog.tree</field>
        <field name="model">methodology.module.catalog</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="technical_name"/>
                <field name="name"/>
                <field name="business_process"/>
                <field name="estimated_hours"/>
                <field name="is_base"/>
            </list>
        </field>
    </record>

    <record id="view_module_catalog_form" model="ir.ui.view">
        <field name="name">methodology.module.catalog.form</field>
        <field name="model">methodology.module.catalog</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="technical_name"/>
                            <field name="business_process"/>
                        </group>
                        <group>
                            <field name="estimated_hours"/>
                            <field name="odoo_edition"/>
                            <field name="is_base"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Descripción..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_module_catalog" model="ir.actions.act_window">
        <field name="name">Catálogo de Módulos</field>
        <field name="res_model">methodology.module.catalog</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_module_catalog" name="Catálogo de Módulos" parent="menu_methodology_config" action="action_module_catalog" sequence="20"/>
</odoo>
