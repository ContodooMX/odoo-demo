<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_generate_workplan_form" model="ir.ui.view">
        <field name="name">methodology.generate.workplan.wizard.form</field>
        <field name="model">methodology.generate.workplan.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="project_id" readonly="1"/>
                    <field name="start_date"/>
                    <field name="include_base_tasks"/>
                </group>
                <group>
                    <field name="module_ids" widget="many2many_checkboxes"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generar Plan" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
